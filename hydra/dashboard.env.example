# Netbird Dashboard environment
# Copy to dashboard.env and fill in your values
# See: https://docs.netbird.io/selfhosted/selfhosted-guide

NETBIRD_MGMT_API_ENDPOINT=https://birdy.example.com:443
NETBIRD_MGMT_GRPC_API_ENDPOINT=https://birdy.example.com:443
AUTH_AUDIENCE=netbird
AUTH_CLIENT_ID=netbird-dashboard
AUTH_AUTHORITY=https://birdy.example.com/oauth2
AUTH_SUPPORTED_SCOPES=openid profile email
AUTH_REDIRECT_URI=
AUTH_SILENT_REDIRECT_URI=
NETBIRD_TOKEN_SOURCE=idToken
